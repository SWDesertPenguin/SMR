{
  "name": "smr",
  "version": "2.0.0",
  "description": "SMR (Standalone Markdown Reader): a simple desktop Markdown reader and editor with tabs",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "test": "node --test test/pure.test.mjs",
    "dist": "electron-builder",
    "dist:portable": "electron-builder --win portable",
    "dist:mac": "electron-builder --mac"
  },
  "author": "",
  "license": "MIT",
  "dependencies": {
    "dompurify": "^3.1.6",
    "highlight.js": "^11.10.0",
    "marked": "^14.1.2"
  },
  "devDependencies": {
    "electron": "^32.1.2",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.smr.app",
    "productName": "SMR",
    "publish": [
      {
        "provider": "github",
        "owner": "SWDesertPenguin",
        "repo": "SMR"
      }
    ],
    "files": [
      "main.js",
      "preload.js",
      "icon-dark.png",
      "src/**/*",
      "node_modules/**/*"
    ],
    "fileAssociations": [
      {
        "ext": "md",
        "name": "Markdown Document",
        "role": "Editor"
      },
      {
        "ext": "markdown",
        "name": "Markdown Document",
        "role": "Editor"
      }
    ],
    "win": {
      "icon": "icon-dark.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "mac": {
      "icon": "icon-dark.png",
      "category": "public.app-category.productivity",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "dmg": {
      "title": "SMR ${version}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "directories": {
      "output": "dist"
    }
  }
}
